<Window x:Class="ImageBrowser.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片信息"
        Width="260"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        MaxHeight="780"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,7,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 信息行 -->
        <Style x:Key="InfoRowStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,7,14,7"/>
            <Setter Property="BorderBrush" Value="#FF363636"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MinHeight" Value="16"/>
        </Style>
    </Window.Resources>

    <Border Background="#DD2B2B2B"
            BorderBrush="#FF484848"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18"
                              ShadowDepth="3" Opacity="0.55" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="#FF252525"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="图片信息"
                               Foreground="#CCCCCC" FontSize="12"
                               VerticalAlignment="Center" Margin="14,0"/>
                    <Button Content="×" Width="36" Height="36"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CloseBtnStyle}"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- 标题栏底部分隔线 -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#FF383838"/>

            <!-- 内容滚动区 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="InfoPanel" Margin="0,2,0,6">

                    <!-- ── 基础信息 ── -->
                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="图片大小" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtFileSize" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="图片尺寸" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDimensions" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="修改时间" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtModifiedTime" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ── 拍摄信息 ── -->
                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="拍摄时间" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDateTaken" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="相机厂商" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtCameraMaker" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="设备型号" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtCameraModel" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="镜头型号" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtLensModel" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="光圈值" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtAperture" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="最大光圈" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtMaxAperture" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="曝光时间" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtExposureTime" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="曝光补偿" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtExposureBias" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ISO 感光度" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtISO" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="焦距" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtFocalLength" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="测光模式" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtMeteringMode" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="闪光灯" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtFlash" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="白平衡" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtWhiteBalance" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="亮度" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtBrightness" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="曝光程序" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtExposureProgram" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ── 软件工具 ── -->
                    <Border Style="{StaticResource InfoRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="软件工具" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtSoftware" Style="{StaticResource ValueStyle}" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ── AI 提示词（仅检测到时显示）── -->
                    <Border x:Name="RowAiPrompt"
                            Style="{StaticResource InfoRowStyle}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="AI 提示词" Foreground="#FF90C208" FontSize="11"/>
                            <TextBlock Grid.Column="1" x:Name="TxtAiPrompt"
                                       Foreground="#CCCCCC" FontSize="11"
                                       TextWrapping="Wrap" MaxHeight="140"
                                       TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ── 完整路径（末行无分隔线）── -->
                    <Border Padding="14,7,14,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="完整路径" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="TxtFilePath"
                                       Foreground="#FF777777" FontSize="11"
                                       TextWrapping="Wrap" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
