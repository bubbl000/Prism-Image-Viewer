<Window x:Class="ImageViewer.SaveAsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="另存为"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="TitleCloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FF4444"/>
                                <Setter Property="Foreground" Value="#FFDDDDDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormatRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#FF252525" CornerRadius="7"
                                BorderThickness="1.5" BorderBrush="#FF383838"
                                Padding="0,10">
                            <StackPanel HorizontalAlignment="Center">
                                <Ellipse x:Name="Dot" Width="8" Height="8"
                                         Fill="#FF444444" HorizontalAlignment="Center"
                                         Margin="0,0,0,6"/>
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A90C208"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF90C208"/>
                                <Setter TargetName="Dot" Property="Fill" Value="#FF90C208"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QualitySlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton>
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#FF90C208" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="#FF90C208"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton>
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#FF303030" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <!-- 阴影层 -->
        <Border CornerRadius="10" Background="#FF2A2A2A">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="22"
                                  ShadowDepth="2" Direction="270" Opacity="0.65"/>
            </Border.Effect>
        </Border>

        <!-- 内容层 -->
        <Border CornerRadius="10" Background="#FF2A2A2A" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="56"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Background="#FF202020"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0,8,0">
                        <TextBlock Text="另存为" Foreground="#DDDDDD" FontSize="13" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource TitleCloseBtn}" Content="✕"
                                HorizontalAlignment="Right" Click="BtnCancel_Click"/>
                    </Grid>
                </Border>

                <!-- 内容 -->
                <StackPanel Grid.Row="1" Margin="20,20,20,8">

                    <TextBlock Text="保存格式" Foreground="#888888" FontSize="11" Margin="2,0,0,8"/>

                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,20">
                        <RadioButton x:Name="RbPng" Content="PNG" GroupName="Fmt"
                                     Style="{StaticResource FormatRadio}" Margin="0,0,6,0"
                                     Checked="Format_Changed"/>
                        <RadioButton x:Name="RbJpg" Content="JPG" GroupName="Fmt"
                                     Style="{StaticResource FormatRadio}" Margin="6,0,0,0"
                                     Checked="Format_Changed"/>
                    </UniformGrid>

                    <!-- 质量面板（仅 JPG） -->
                    <Border x:Name="QualityPanel" Visibility="Collapsed"
                            Background="#FF1E1E1E" CornerRadius="8" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="52"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="图片质量" Foreground="#777777" FontSize="11" Margin="0,0,0,8"/>
                                    <Slider x:Name="SliderQuality"
                                            Minimum="1" Maximum="100" Value="100"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            Style="{StaticResource QualitySlider}"
                                            ValueChanged="SliderQuality_ValueChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock x:Name="TxtQualityPct"
                                               Foreground="#EEEEEE" FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center" Text="100"/>
                                    <TextBlock Text="%" Foreground="#777777" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#FF2E2E2E" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="预计大小" Foreground="#777777" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtSizePreview" Grid.Column="1"
                                           Foreground="#CCCCCC" FontSize="12" FontWeight="Medium"
                                           VerticalAlignment="Center" Text="计算中…"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Grid.Row="2" Height="1" Background="#FF2E2E2E"/>

                <!-- 按钮 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <Button Content="取消" Width="76" Height="34" Margin="0,0,10,0"
                            Style="{StaticResource DialogBtnSecondary}" Click="BtnCancel_Click"/>
                    <Button Content="确认" Width="76" Height="34"
                            Style="{StaticResource DialogBtnPrimary}"
                            Click="BtnOK_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
