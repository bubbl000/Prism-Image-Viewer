<Window x:Class="ImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:paz="clr-namespace:Wpf.Controls.PanAndZoom;assembly=Wpf.Controls.PanAndZoom"
        Icon="Assets/icon.ico"
        Title="图片浏览器 V2.0"
        Height="600" Width="900"
        MinHeight="300" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- 窗口控制按钮 -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 空状态打开按钮 -->
        <Style x:Key="OpenBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF90C208"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF7AAD06"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 左右导航按钮 -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#99000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 底部工具栏按钮 -->
        <Style x:Key="ToolBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GIF 帧滑条 -->
        <Style x:Key="GifSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20" VerticalAlignment="Center">
                            <Track x:Name="PART_Track" Margin="7,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#FF90C208" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#FF3A3A3A" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" CornerRadius="7"
                                                        Background="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 工具栏竖分隔线 -->
        <Style x:Key="VDivStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Fill" Value="#FF404040"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 弹出菜单行按钮 -->
        <Style x:Key="PopupRowStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <!-- ══ 缩放拖拽边缘（在 ClipToBounds 之外，必须放最外层）══ -->
    <Grid Panel.ZIndex="999">
        <Border HorizontalAlignment="Left"  Width="6"  Cursor="SizeWE"   Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="Left"/>
        <Border HorizontalAlignment="Right" Width="6"  Cursor="SizeWE"   Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="Right"/>
        <Border VerticalAlignment="Top"    Height="6"  Cursor="SizeNS"   Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="Top"/>
        <Border VerticalAlignment="Bottom" Height="6"  Cursor="SizeNS"   Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="Bottom"/>
        <Border HorizontalAlignment="Left"  VerticalAlignment="Top"    Width="10" Height="10" Cursor="SizeNWSE" Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="TopLeft"/>
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"    Width="10" Height="10" Cursor="SizeNESW" Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="TopRight"/>
        <Border HorizontalAlignment="Left"  VerticalAlignment="Bottom" Width="10" Height="10" Cursor="SizeNESW" Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="BottomLeft"/>
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="10" Height="10" Cursor="SizeNWSE" Background="Transparent" PreviewMouseLeftButtonDown="ResizeEdge_MouseDown" Tag="BottomRight"/>
    </Grid>

    <Border x:Name="MainBorder" Background="#FF1A1A1A" CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ 标题栏 ══════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="#FF2A2A2A"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="Assets/icon.ico" Width="16" Height="16"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="图片浏览器"
                                   Foreground="#777777" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFileName" Foreground="#CCCCCC" FontSize="12"/>
                        <TextBlock x:Name="TxtSep1" Text=" | "
                                   Foreground="#555555" FontSize="12" Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtDimensions"
                                   Foreground="#888888" FontSize="12" Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtSep2" Text=" | "
                                   Foreground="#555555" FontSize="12" Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtFileSize"
                                   Foreground="#888888" FontSize="12" Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnSettings" Content="≡" Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}" Click="BtnSettings_Click"
                                FontSize="14" Padding="0,0,0,2"/>
                        <Button x:Name="BtnFullscreen" Content="⛶" Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}" Click="BtnFullscreen_Click"
                                FontSize="13" ToolTip="全屏"/>
                        <Button x:Name="BtnMinimize" Content="−" Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="□" Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}" Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="×" Width="32" Height="25"
                                Style="{StaticResource CloseBtnStyle}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ 图片区域 ════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Background="#FF1A1A1A"
                  x:Name="ContentGrid">

                <paz:ZoomBorder x:Name="ZoomBorder"
                                Stretch="Uniform" ZoomSpeed="1.2"
                                EnableInput="True" ClipToBounds="True"
                                Background="Transparent"
                                PreviewMouseLeftButtonDown="ZoomBorder_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="ZoomBorder_PreviewMouseMove"
                                PreviewMouseLeftButtonUp="ZoomBorder_PreviewMouseLeftButtonUp"
                                LayoutUpdated="ZoomBorder_LayoutUpdated"
                                ContextMenuOpening="ZoomBorder_ContextMenuOpening">
                    <paz:ZoomBorder.ContextMenu>
                        <ContextMenu Background="#FF2C2C2C" BorderBrush="#FF484848" BorderThickness="1">
                            <ContextMenu.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="18"
                                                  ShadowDepth="3" Opacity="0.55" Direction="270"/>
                            </ContextMenu.Effect>
                            <ContextMenu.Template>
                                <ControlTemplate TargetType="ContextMenu">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8"
                                            Padding="8,4">
                                        <StackPanel IsItemsHost="True"/>
                                    </Border>
                                </ControlTemplate>
                            </ContextMenu.Template>
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Height" Value="32"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,0,10,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Bd"
                                                        Background="Transparent"
                                                        CornerRadius="5"
                                                        Margin="0,1"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter ContentSource="Header"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"
                                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem Header="重命名" Click="MenuRename_Click"/>
                            <MenuItem Header="另存为..." Click="MenuSaveAs_Click"/>
                            <MenuItem Header="复制" Click="MenuCopy_Click"/>
<MenuItem Header="资源管理器中打开" Click="MenuOpenInExplorer_Click"/>
                            <MenuItem Header="复制文件路径" Click="MenuCopyPath_Click"/>
                            <MenuItem Header="设为壁纸" Click="MenuSetWallpaper_Click"/>
                            <MenuItem Click="MenuDelete_Click" Foreground="#FF6B6B">
                                <MenuItem.Header>
                                    <TextBlock Text="删除" Foreground="#FF6B6B"/>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Header="打印..." Click="MenuPrint_Click"/>
                        </ContextMenu>
                    </paz:ZoomBorder.ContextMenu>
                    <Image x:Name="MainImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.LayoutTransform>
                            <RotateTransform x:Name="ImageRotation" Angle="0"/>
                        </Image.LayoutTransform>
                    </Image>
                </paz:ZoomBorder>

                <Button x:Name="BtnPrev" Content="❮"
                        Style="{StaticResource NavBtnStyle}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="10,0" Visibility="Collapsed" Click="BtnPrev_Click"/>

                <Button x:Name="BtnNext" Content="❯"
                        Style="{StaticResource NavBtnStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="10,0" Visibility="Collapsed" Click="BtnNext_Click"/>

                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📂" FontSize="52"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="拖放图片或文件夹到此处"
                               Foreground="#555555" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="支持 JPG / PNG / BMP / GIF / TIFF / WEBP"
                               Foreground="#404040" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Content="选择图片" Width="110" Height="36"
                            Click="BtnOpenFile_Click"
                            Style="{StaticResource OpenBtnStyle}"/>
                </StackPanel>

                <Border x:Name="DropOverlay" Background="#AA90C208" Visibility="Collapsed">
                    <TextBlock Text="松开以打开" Foreground="White" FontSize="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 加载提示（延迟 400ms 才显示） -->
                <Border x:Name="LoadingOverlay" Background="#AA000000"
                        Visibility="Collapsed" Panel.ZIndex="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Vertical" Margin="20">
                        <TextBlock x:Name="LoadingText" Text="正在加载…" Foreground="White" 
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <ProgressBar x:Name="LoadingProgressBar" Width="200" Height="8"
                                     IsIndeterminate="True" Foreground="#FF4CAF50"/>
                        <TextBlock x:Name="LoadingSubText" Text="" Foreground="#CCCCCC" 
                                   FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- GIF 控制面板 -->
                <Border x:Name="GifPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,60,0,0"
                        Background="#CC252525"
                        BorderBrush="#FF404040" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Panel.ZIndex="10"
                        MouseLeftButtonDown="GifPanel_MouseLeftButtonDown">
                    <StackPanel Margin="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,6">
                            <Button x:Name="BtnGifFirst" Content="◀" Width="28" Height="28"
                                    Style="{StaticResource ToolBtnStyle}"
                                    ToolTip="上一帧"
                                    Click="BtnGifFirst_Click"/>
                            <Button x:Name="BtnGifPlayPause" Content="⏸" Width="28" Height="28"
                                    Style="{StaticResource ToolBtnStyle}" Margin="2,0"
                                    ToolTip="播放 / 暂停"
                                    Click="BtnGifPlayPause_Click"/>
                            <Button x:Name="BtnGifLast" Content="▶" Width="28" Height="28"
                                    Style="{StaticResource ToolBtnStyle}"
                                    ToolTip="下一帧"
                                    Click="BtnGifLast_Click"/>
                            <TextBlock x:Name="TxtGifFrame" Text="1 / 1"
                                       Foreground="#AAAAAA" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Slider x:Name="GifSlider" Width="200" Minimum="0" Maximum="0"
                                SmallChange="1" LargeChange="5"
                                Style="{StaticResource GifSliderStyle}"
                                ValueChanged="GifSlider_ValueChanged"/>
                    </StackPanel>
                </Border>

                <!-- ══ 鸟瞰图 ════════════════════════════════════════════ -->
                <Border x:Name="BirdEyePanel"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,10,144"
                        Background="#CC1A1A1A"
                        BorderBrush="#FF444444"
                        BorderThickness="1"
                        CornerRadius="5"
                        ClipToBounds="True"
                        Visibility="Collapsed">
                    <Grid x:Name="BirdEyeGrid" Width="180" Height="114">
                        <Image x:Name="BirdEyeImage" Stretch="Uniform"/>
                        <Canvas x:Name="BirdEyeCanvas" Width="180" Height="114">
                            <Rectangle x:Name="BirdEyeRect"
                                       Stroke="#FF90C208" StrokeThickness="1.5"
                                       Fill="#2290C208"/>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- 全屏退出按钮（仅全屏时可见） -->
                <Border x:Name="FullscreenExitOverlay"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Visibility="Collapsed"
                        Panel.ZIndex="100">
                    <Button Click="BtnExitFullscreen_Click"
                            Background="#99000000" Foreground="White"
                            BorderThickness="0" Padding="12,6" FontSize="12"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="✕ 退出全屏"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#CC000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!-- ══ 底部悬浮面板（缩略图 + 工具栏） ══════════════ -->
                <Grid x:Name="BottomPanel" VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="46"/>
                    </Grid.RowDefinitions>

                    <!-- 缩略图栏 -->
                    <Border x:Name="ThumbStrip"
                            Grid.Row="0"
                            Height="88"
                            Background="#FF252525"
                            BorderThickness="0"
                            Visibility="Collapsed"
                            MouseEnter="HotZone_MouseEnter"
                            MouseLeave="HotZone_MouseLeave">
                        <ScrollViewer x:Name="ThumbScroll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="ThumbPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="6,0"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 工具栏 -->
                    <Border Grid.Row="1" Background="#FF252525"
                            MouseEnter="HotZone_MouseEnter"
                            MouseLeave="HotZone_MouseLeave">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左：ℹ + 缩放% + 序号 -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnInfo" Content="ℹ"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="图片信息" Click="BtnInfo_Click"/>
                                <Rectangle Style="{StaticResource VDivStyle}"/>
                                <Border Background="#FF333333" CornerRadius="4"
                                        Height="26" VerticalAlignment="Center" Padding="8,0">
                                    <TextBlock x:Name="TxtZoom" Text="100%"
                                               Foreground="#BBBBBB" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtIndex"
                                           Foreground="#555555" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 右：旋转 + 宽度适应 + 原始大小 + 更多 + 弹出菜单 -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnRotateLeft" Content="↺"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="向左旋转 90°" Click="BtnRotateLeft_Click"/>
                                <Button x:Name="BtnRotateRight" Content="↻"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="向右旋转 90°" Click="BtnRotateRight_Click"/>
                                <Rectangle Style="{StaticResource VDivStyle}"/>
                                <Button x:Name="BtnFitWidth" Content="↔"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="适应窗口" Click="BtnFitWidth_Click"/>
                                <Button x:Name="BtnActualSize"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="原始大小 (1:1像素)" Click="BtnActualSize_Click">
                                    <Viewbox Width="15" Height="15">
                                        <Canvas Width="18" Height="18">
                                            <!-- 虚线方框 -->
                                            <Rectangle Canvas.Left="1" Canvas.Top="1"
                                                       Width="16" Height="16"
                                                       StrokeThickness="1.2"
                                                       StrokeDashArray="3,2"
                                                       Fill="Transparent"
                                                       Stroke="{Binding Foreground,
                                                           RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            <!-- 倾斜双向箭头（↗↙），含两端箭头 -->
                                            <Path StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Data="M 4,14 L 14,4 M 11,4 L 14,4 L 14,7 M 7,14 L 4,14 L 4,11"
                                                  Stroke="{Binding Foreground,
                                                      RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Rectangle Style="{StaticResource VDivStyle}"/>
                                <Button x:Name="BtnMore" Content="⋯"
                                        Style="{StaticResource ToolBtnStyle}"
                                        ToolTip="更多" Click="BtnMore_Click"/>

                                <!-- 自定义弹出菜单 -->
                                <Popup x:Name="MorePopup"
                                       PlacementTarget="{Binding ElementName=BtnMore}"
                                       Placement="Top"
                                       VerticalOffset="-6"
                                       HorizontalOffset="-178"
                                       AllowsTransparency="True"
                                       StaysOpen="False"
                                       PopupAnimation="Fade">
                                    <Border Background="#FF2C2C2C"
                                            BorderBrush="#FF484848"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="18"
                                                              ShadowDepth="3" Opacity="0.55"
                                                              Direction="270"/>
                                        </Border.Effect>
                                        <StackPanel Width="212">

                                            <!-- 缩略图栏 开关 -->
                                            <Button Style="{StaticResource PopupRowStyle}"
                                                    Click="MenuThumb_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="缩略图栏"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" x:Name="ThumbPill"
                                                            Width="34" Height="18" CornerRadius="9"
                                                            Background="#FF3A3A3A"
                                                            VerticalAlignment="Center"
                                                            ClipToBounds="True">
                                                        <Canvas Width="34" Height="18">
                                                            <Border x:Name="ThumbDotSlider"
                                                                    Width="14" Height="14" CornerRadius="7"
                                                                    Background="White"
                                                                    Canvas.Left="2" Canvas.Top="2"/>
                                                        </Canvas>
                                                    </Border>
                                                </Grid>
                                            </Button>

                                            <!-- 智能展示 开关 -->
                                            <Button Style="{StaticResource PopupRowStyle}"
                                                    Click="MenuSmart_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="智能展示"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" x:Name="SmartPill"
                                                            Width="34" Height="18" CornerRadius="9"
                                                            Background="#FF3A3A3A"
                                                            VerticalAlignment="Center"
                                                            ClipToBounds="True">
                                                        <Canvas Width="34" Height="18">
                                                            <Border x:Name="SmartDotSlider"
                                                                    Width="14" Height="14" CornerRadius="7"
                                                                    Background="White"
                                                                    Canvas.Left="2" Canvas.Top="2"/>
                                                        </Canvas>
                                                    </Border>
                                                </Grid>
                                            </Button>

                                            <!-- 鸟瞰图 开关 -->
                                            <Button Style="{StaticResource PopupRowStyle}"
                                                    Click="MenuBirdEye_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="鸟瞰图"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" x:Name="BirdEyePill"
                                                            Width="34" Height="18" CornerRadius="9"
                                                            Background="#FF3A3A3A"
                                                            VerticalAlignment="Center"
                                                            ClipToBounds="True">
                                                        <Canvas Width="34" Height="18">
                                                            <Border x:Name="BirdEyeDotSlider"
                                                                    Width="14" Height="14" CornerRadius="7"
                                                                    Background="White"
                                                                    Canvas.Left="2" Canvas.Top="2"/>
                                                        </Canvas>
                                                    </Border>
                                                </Grid>
                                            </Button>

                                            <!-- 文件夹穿透 开关 -->
                                            <Button Style="{StaticResource PopupRowStyle}"
                                                    Click="MenuFolderTraverse_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="文件夹穿透"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" x:Name="FolderTraversePill"
                                                            Width="34" Height="18" CornerRadius="9"
                                                            Background="#FF3A3A3A"
                                                            VerticalAlignment="Center"
                                                            ClipToBounds="True">
                                                        <Canvas Width="34" Height="18">
                                                            <Border x:Name="FolderTraverseDotSlider"
                                                                    Width="14" Height="14" CornerRadius="7"
                                                                    Background="White"
                                                                    Canvas.Left="2" Canvas.Top="2"/>
                                                        </Canvas>
                                                    </Border>
                                                </Grid>
                                            </Button>

                                            <Rectangle Height="1" Fill="#FF383838" Margin="8,4"/>

                                            <!-- 提示（不可点击） -->
                                            <TextBlock Text="Ctrl+拖拽 → 拖出到其他程序"
                                                       Foreground="#4A4A4A" FontSize="11"
                                                       Margin="12,4,12,6"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
    </Grid>
</Window>
