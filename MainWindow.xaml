<Window x:Class="ImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:paz="clr-namespace:Wpf.Controls.PanAndZoom;assembly=Wpf.Controls.PanAndZoom"
        Title="图片浏览器 V1.2"
        Height="600" Width="900"
        MinHeight="300" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- 窗口控制按钮 -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 空状态打开按钮 -->
        <Style x:Key="OpenBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 左右导航按钮 -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#99000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 底部工具栏按钮 -->
        <Style x:Key="ToolBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 工具栏竖分隔线 -->
        <Style x:Key="VDivStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Fill" Value="#FF404040"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="#FF1A1A1A" CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="88"/>
                <RowDefinition Height="46"/>
            </Grid.RowDefinitions>

            <!-- ══ 标题栏 ══════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="#FF2A2A2A"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：应用名 -->
                    <TextBlock Grid.Column="0"
                               Text="图片浏览器"
                               Foreground="#777777"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>

                    <!-- 中：文件信息  文件名 | 尺寸 | 大小 -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFileName"
                                   Foreground="#CCCCCC"
                                   FontSize="12"/>
                        <TextBlock x:Name="TxtSep1" Text=" | "
                                   Foreground="#555555" FontSize="12"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtDimensions"
                                   Foreground="#888888" FontSize="12"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtSep2" Text=" | "
                                   Foreground="#555555" FontSize="12"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtFileSize"
                                   Foreground="#888888" FontSize="12"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- 右：索引 + 窗口按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtIndex"
                                   Foreground="#555555"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Button x:Name="BtnMinimize" Content="−"
                                Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="□"
                                Width="32" Height="25"
                                Style="{StaticResource WinBtnStyle}"
                                Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="×"
                                Width="32" Height="25"
                                Style="{StaticResource CloseBtnStyle}"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ 图片区域 ════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Background="#FF1A1A1A"
                  x:Name="ContentGrid">

                <!-- 图片缩放/平移控件（PanAndZoom） -->
                <paz:ZoomBorder x:Name="ZoomBorder"
                                Stretch="Uniform"
                                ZoomSpeed="1.2"
                                EnableInput="True"
                                ClipToBounds="True"
                                Background="Transparent"
                                PreviewMouseLeftButtonDown="ZoomBorder_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="ZoomBorder_PreviewMouseMove"
                                LayoutUpdated="ZoomBorder_LayoutUpdated">
                    <Image x:Name="MainImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.LayoutTransform>
                            <RotateTransform x:Name="ImageRotation" Angle="0"/>
                        </Image.LayoutTransform>
                    </Image>
                </paz:ZoomBorder>

                <!-- 左导航按钮 -->
                <Button x:Name="BtnPrev"
                        Content="❮"
                        Style="{StaticResource NavBtnStyle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0"
                        Visibility="Collapsed"
                        Click="BtnPrev_Click"/>

                <!-- 右导航按钮 -->
                <Button x:Name="BtnNext"
                        Content="❯"
                        Style="{StaticResource NavBtnStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="10,0"
                        Visibility="Collapsed"
                        Click="BtnNext_Click"/>

                <!-- 空状态提示 -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="📂" FontSize="52"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="拖放图片或文件夹到此处"
                               Foreground="#555555" FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="支持 JPG / PNG / BMP / GIF / TIFF / WEBP"
                               Foreground="#404040" FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"/>
                    <Button Content="选择图片"
                            Width="110" Height="36"
                            Click="BtnOpenFile_Click"
                            Style="{StaticResource OpenBtnStyle}"/>
                </StackPanel>

                <!-- 拖放高亮遮罩 -->
                <Border x:Name="DropOverlay"
                        Background="#AA0078D4"
                        Visibility="Collapsed">
                    <TextBlock Text="松开以打开"
                               Foreground="White" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ══ 缩略图栏 ════════════════════════════════════════════ -->
            <Border x:Name="ThumbStrip"
                    Grid.Row="2"
                    Background="#FF1E1E1E"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#FF2E2E2E"
                    Visibility="Collapsed">
                <ScrollViewer x:Name="ThumbScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ThumbPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,0"/>
                </ScrollViewer>
            </Border>

            <!-- ══ 底部工具栏 ══════════════════════════════════════════ -->
            <Border Grid.Row="3" Background="#FF252525">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：信息 + 缩放百分比 -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnInfo" Content="ℹ"
                                Style="{StaticResource ToolBtnStyle}"
                                ToolTip="图片信息"
                                Click="BtnInfo_Click"/>
                        <Rectangle Style="{StaticResource VDivStyle}"/>
                        <Border Background="#FF333333" CornerRadius="4"
                                Width="60" Height="26"
                                VerticalAlignment="Center">
                            <TextBox x:Name="TxtZoom"
                                     Text="100%"
                                     Background="Transparent"
                                     Foreground="#BBBBBB"
                                     BorderThickness="0"
                                     TextAlignment="Center"
                                     VerticalAlignment="Center"
                                     FontSize="12"
                                     CaretBrush="#BBBBBB"
                                     SelectionBrush="#440078D4"
                                     KeyDown="TxtZoom_KeyDown"
                                     GotFocus="TxtZoom_GotFocus"
                                     LostFocus="TxtZoom_LostFocus"/>
                        </Border>
                    </StackPanel>

                    <!-- 右：旋转 + 更多 -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnRotateLeft" Content="↺"
                                Style="{StaticResource ToolBtnStyle}"
                                ToolTip="向左旋转 90°"
                                Click="BtnRotateLeft_Click"/>
                        <Button x:Name="BtnRotateRight" Content="↻"
                                Style="{StaticResource ToolBtnStyle}"
                                ToolTip="向右旋转 90°"
                                Click="BtnRotateRight_Click"/>
                        <Rectangle Style="{StaticResource VDivStyle}"/>
                        <!-- 更多（ContextMenu 不触发主窗口事件，安全） -->
                        <Button x:Name="BtnMore" Content="⋯"
                                Style="{StaticResource ToolBtnStyle}"
                                ToolTip="更多"
                                Click="BtnMore_Click">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreMenu">
                                    <MenuItem Header="在资源管理器中显示"
                                              Click="MenuShowInExplorer_Click"/>
                                    <Separator/>
                                    <MenuItem Header="复制文件路径"
                                              Click="MenuCopyPath_Click"/>
                                    <MenuItem Header="Ctrl+拖拽 → 拖出到其他程序"
                                              IsEnabled="False" Foreground="#888888"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
