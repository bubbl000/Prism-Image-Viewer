<Window x:Class="ImageViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="700" Height="520" MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- ── 窗口按钮 ──────────────────────────────────────────── -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── iOS Toggle ─────────────────────────────────────────── -->
        <Style x:Key="iOSToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Pill" Background="#3A3A3A" CornerRadius="12"
                                    Width="44" Height="24"/>
                            <Border x:Name="Dot" Width="18" Height="18" Background="White"
                                    CornerRadius="9" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#90C208"/>
                                <Setter TargetName="Dot" Property="Margin" Value="23,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 导航按钮（默认/选中） ─────────────────────────────── -->
        <Style x:Key="NavBtn" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ── 设置卡片 ─────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FF252525"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ── 单选按钮 ─────────────────────────────────────────── -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Circle" Width="16" Height="16" CornerRadius="8"
                                    BorderBrush="#555" BorderThickness="1.5"
                                    Background="Transparent" Margin="0,0,6,0">
                                <Ellipse x:Name="Dot" Width="8" Height="8"
                                         Fill="#90C208" Visibility="Collapsed"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Circle" Property="BorderBrush" Value="#90C208"/>
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="BorderBrush" Value="#90C208"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 复选框（文件关联用） ─────────────────────────────── -->
        <Style x:Key="AssocCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ── Slider ───────────────────────────────────────────── -->
        <Style x:Key="GreenSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#90C208" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#3A3A3A" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="White" CornerRadius="8"
                                                        Width="16" Height="16"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── 外框 ────────────────────────────────────────────────────── -->
    <Border x:Name="RootBorder"
            Background="#FF1A1A1A"
            BorderBrush="#FF404040" BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 标题栏 ────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#FF242424" CornerRadius="10,10,0,0"
                    x:Name="TitleBar" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="设置"
                               Foreground="#CCCCCC" FontSize="12"
                               VerticalAlignment="Center" Margin="14,0"/>
                    <Button Content="×" Width="32" Height="32"
                            Style="{StaticResource CloseBtn}"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- ── 内容区 ────────────────────────────────────────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── 左侧导航 ───────────────────────────────── -->
                <Border Grid.Column="0" Background="#FF1E1E1E"
                        BorderBrush="#FF303030" BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,10">
                    <DockPanel>
                        <!-- 顶部导航项 -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                            <Border x:Name="NavFileAssoc" Style="{StaticResource NavBtn}"
                                    MouseLeftButtonDown="NavFileAssoc_Click"
                                    Background="#1A90C208">
                                <TextBlock Text="{DynamicResource Nav.FileAssoc}"
                                           Foreground="#DDDDDD" FontSize="12"/>
                            </Border>
                            <Border x:Name="NavGeneral" Style="{StaticResource NavBtn}"
                                    MouseLeftButtonDown="NavGeneral_Click">
                                <TextBlock Text="{DynamicResource Nav.General}"
                                           Foreground="#888888" FontSize="12"/>
                            </Border>
                            <Border x:Name="NavHabits" Style="{StaticResource NavBtn}"
                                    MouseLeftButtonDown="NavHabits_Click">
                                <TextBlock Text="{DynamicResource Nav.Habits}"
                                           Foreground="#888888" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <!-- 底部：语言 + 关于 -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12">
                            <Separator Background="#333" Margin="0,0,0,10"/>

                            <!-- 语言 -->
                            <TextBlock Text="{DynamicResource Lang.Label}"
                                       Foreground="#666" FontSize="10" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CboLanguage" FontSize="11"
                                      SelectionChanged="CboLanguage_SelectionChanged">
                                <ComboBoxItem Tag="zh-CN" Content="{DynamicResource Lang.ZhCN}"/>
                                <ComboBoxItem Tag="en-US" Content="{DynamicResource Lang.EnUS}"/>
                            </ComboBox>

                            <Separator Background="#333" Margin="0,0,0,10"/>

                            <!-- 版本信息 -->
                            <TextBlock Text="ImageViewer" Foreground="#555" FontSize="10"/>
                            <TextBlock Text="{DynamicResource About.Version}"
                                       Foreground="#444" FontSize="10" Margin="0,1,0,0"/>
                        </StackPanel>

                        <StackPanel/><!-- spacer -->
                    </DockPanel>
                </Border>

                <!-- ── 右侧内容区 ─────────────────────────────── -->
                <Grid Grid.Column="1">
                    <!-- 文件关联 -->
                    <ScrollViewer x:Name="ScrollFileAssoc" VerticalScrollBarVisibility="Auto"
                                  Padding="20,16,20,16" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Nav.FileAssoc}"
                                       Foreground="#90C208" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource FileAssoc.Desc}"
                                               Foreground="#777" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <WrapPanel Margin="0,0,0,10">
                                        <CheckBox x:Name="ChkJpg"   Content="JPG / JPEG" IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkPng"   Content="PNG"         IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkBmp"   Content="BMP"         IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkGif"   Content="GIF"         IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkTiff"  Content="TIFF / TIF"  IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkWebp"  Content="WebP"        IsChecked="True" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkIco"   Content="ICO"         IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkHeic"  Content="HEIC"        IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkHeif"  Content="HEIF"        IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkAvif"  Content="AVIF"        IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkSvg"   Content="SVG"         IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkRaw"   Content="RAW"         IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkCr3"   Content="CR3"         IsChecked="False" Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkPsd"   Content="PSD"         IsChecked="True"  Style="{StaticResource AssocCheck}"/>
                                        <CheckBox x:Name="ChkPsb"   Content="PSB"         IsChecked="True"  Style="{StaticResource AssocCheck}"/>
                                    </WrapPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource FileAssoc.SelectAll}"
                                                Width="60" Height="26" Margin="0,0,8,0"
                                                Style="{StaticResource WinBtn}"
                                                FontSize="11" Background="#FF2E2E2E" Foreground="#AAAAAA"
                                                Click="BtnAssocAll_Click"/>
                                        <Button Content="{DynamicResource FileAssoc.SelectNone}"
                                                Width="72" Height="26" Margin="0,0,10,0"
                                                Style="{StaticResource WinBtn}"
                                                FontSize="11" Background="#FF2E2E2E" Foreground="#AAAAAA"
                                                Click="BtnAssocNone_Click"/>
                                        <Button x:Name="BtnAssociate" Height="26" Padding="10,0"
                                                FontSize="11" Foreground="White" Background="#FF90C208"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="BtnAssociate_Click">
                                            <Button.Content>
                                                <TextBlock Text="{DynamicResource FileAssoc.Associate}"/>
                                            </Button.Content>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FF7AAD06"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 常规设置 -->
                    <ScrollViewer x:Name="ScrollGeneral" VerticalScrollBarVisibility="Auto"
                                  Padding="20,16,20,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Nav.General}"
                                       Foreground="#90C208" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <!-- 硬件加速渲染 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource General.HwAccel}"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="{DynamicResource General.HwAccel.Desc}"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkHwAccel" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkHwAccel_Changed"
                                              Unchecked="ChkHwAccel_Changed"/>
                                </Grid>
                            </Border>

                            <!-- 记住窗口位置 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource General.RememberPos}"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="{DynamicResource General.RememberPos.Desc}"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkRememberPos" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkRememberPos_Changed"
                                              Unchecked="ChkRememberPos_Changed"/>
                                </Grid>
                            </Border>

                            <!-- 原始像素模式 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource General.PixelMode}"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="{DynamicResource General.PixelMode.Desc}"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkPixelMode" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkPixelMode_Changed"
                                              Unchecked="ChkPixelMode_Changed"/>
                                </Grid>
                            </Border>

                            <!-- RAW 原件查看 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource General.RawOriginalView}"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="{DynamicResource General.RawOriginalView.Desc}"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkRawOriginal" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkRawOriginal_Changed"
                                              Unchecked="ChkRawOriginal_Changed"/>
                                </Grid>
                            </Border>

                            <!-- 专业格式缩放 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="专业格式缩放"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="PSD/PSB 文件超过 4K 分辨率时自动缩放到 4K 以内，提升加载速度"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkProfessionalScale" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkProfessionalScale_Changed"
                                              Unchecked="ChkProfessionalScale_Changed"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- 习惯设置 -->
                    <ScrollViewer x:Name="ScrollHabits" VerticalScrollBarVisibility="Auto"
                                  Padding="20,16,20,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Nav.Habits}"
                                       Foreground="#90C208" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <!-- 多窗口 -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Habits.MultiWindow}"
                                                   Foreground="#CCCCCC" FontSize="12"/>
                                        <TextBlock Text="{DynamicResource Habits.MultiWindow.Desc}"
                                                   Foreground="#666" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,12,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkMultiWindow" Grid.Column="1"
                                              Style="{StaticResource iOSToggle}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"
                                              Checked="ChkMultiWindow_Changed"
                                              Unchecked="ChkMultiWindow_Changed"/>
                                </Grid>
                            </Border>



                            <!-- 滚轮模式 -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Habits.WheelMode}"
                                               Foreground="#CCCCCC" FontSize="12"/>
                                    <TextBlock Text="{DynamicResource Habits.WheelMode.Desc}"
                                               Foreground="#666" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="RbWheelZoom" GroupName="WheelMode"
                                                     Style="{StaticResource DarkRadio}"
                                                     IsChecked="True"
                                                     Checked="WheelMode_Changed">
                                            <TextBlock Text="{DynamicResource Habits.WheelMode.Zoom}"
                                                       Foreground="#CCCCCC" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton x:Name="RbWheelPage" GroupName="WheelMode"
                                                     Style="{StaticResource DarkRadio}"
                                                     Checked="WheelMode_Changed">
                                            <TextBlock Text="{DynamicResource Habits.WheelMode.Page}"
                                                       Foreground="#CCCCCC" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton x:Name="RbWheelScroll" GroupName="WheelMode"
                                                     Style="{StaticResource DarkRadio}"
                                                     Checked="WheelMode_Changed">
                                            <TextBlock Text="{DynamicResource Habits.WheelMode.Scroll}"
                                                       Foreground="#CCCCCC" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
