<Window x:Class="ImageViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1A1A1A"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- 窗口按钮样式 -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 设置项样式 -->
        <Style x:Key="SettingItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF252525"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Toggle 开关样式 -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Pill"
                                    Background="#3A3A3A"
                                    CornerRadius="12"
                                    Width="44" Height="24"/>
                            <Ellipse x:Name="Dot"
                                     Fill="White"
                                     Width="18" Height="18"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#90C208"/>
                                <Setter TargetName="Dot" Property="Margin" Value="23,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#FF404040" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#FF2A2A2A" x:Name="TitleBar"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="设置" Foreground="#CCCCCC" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <Button Content="×" Width="32" Height="32"
                            Style="{StaticResource CloseBtnStyle}"
                            HorizontalAlignment="Right"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                <StackPanel>
                    <TextBlock Text="界面设置" Foreground="#90C208" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Style="{StaticResource SettingItemStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="缩略图栏" Foreground="#CCCCCC" FontSize="13"/>
                                <TextBlock Text="始终显示底部缩略图栏" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="ChkThumbAlwaysOn"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="ChkThumbAlwaysOn_Checked"
                                      Unchecked="ChkThumbAlwaysOn_Unchecked"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingItemStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="智能展示" Foreground="#CCCCCC" FontSize="13"/>
                                <TextBlock Text="鼠标悬停时显示缩略图栏" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="ChkSmartThumb"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="ChkSmartThumb_Checked"
                                      Unchecked="ChkSmartThumb_Unchecked"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingItemStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="鸟瞰图" Foreground="#CCCCCC" FontSize="13"/>
                                <TextBlock Text="右上角显示全图缩略图和可视区域" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="ChkBirdEye"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="ChkBirdEye_Checked"
                                      Unchecked="ChkBirdEye_Unchecked"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingItemStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="文件夹穿透" Foreground="#CCCCCC" FontSize="13"/>
                                <TextBlock Text="到达边界时进入相邻文件夹" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="ChkFolderTraverse"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="ChkFolderTraverse_Checked"
                                      Unchecked="ChkFolderTraverse_Unchecked"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="关于" Foreground="#90C208" FontSize="14"
                               FontWeight="SemiBold" Margin="0,16,0,12"/>

                    <Border Style="{StaticResource SettingItemStyle}">
                        <StackPanel>
                            <TextBlock Text="ImageViewer" Foreground="#CCCCCC" FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="版本 2.1" Foreground="#888888" FontSize="12"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="WPF 图片浏览器，支持多格式浏览、缩略图、缩放平移、旋转、右键菜单、文件监视等。"
                                       Foreground="#666666" FontSize="11"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
