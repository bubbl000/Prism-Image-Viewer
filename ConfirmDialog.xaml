<Window x:Class="ImageBrowser.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="#DD2B2B2B"
            BorderBrush="#FF484848"
            BorderThickness="1"
            CornerRadius="10"
            Padding="24,20,24,16"
            MinWidth="280" MaxWidth="380">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="4" Opacity="0.6" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <!-- 标题 -->
            <TextBlock x:Name="TxtTitle"
                       Foreground="#EEEEEE" FontSize="14" FontWeight="SemiBold"
                       Margin="0,0,0,10" TextWrapping="Wrap"/>
            <!-- 消息 -->
            <TextBlock x:Name="TxtMessage"
                       Foreground="#AAAAAA" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,20"/>
            <!-- 按钮区 -->
            <StackPanel x:Name="ButtonPanel"
                        Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="取消"
                        Width="72" Height="30" Margin="0,0,8,0"
                        Click="BtnCancel_Click"
                        Style="{StaticResource DialogBtnSecondary}"/>
                <Button x:Name="BtnConfirm" Content="确定"
                        Width="72" Height="30"
                        Click="BtnConfirm_Click"
                        Style="{StaticResource DialogBtnPrimary}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
