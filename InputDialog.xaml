<Window x:Class="ImageBrowser.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        Height="160" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="{Binding Message}" Grid.Row="0" Margin="0,0,0,10"/>
        
        <TextBox x:Name="InputTextBox" Grid.Row="1" 
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#3D3D3D"
                 Padding="5"
                 Margin="0,0,0,15"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Margin="0,0,10,0" Click="OkButton_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Width="80" Click="CancelButton_Click"
                    Background="#3D3D3D" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
