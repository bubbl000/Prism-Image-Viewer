<Window x:Class="ImageBrowser.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名"
        Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="DialogBtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#FF90C208"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF7AAD06"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF6E9C05"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogBtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF484848"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E2E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FF2A2A2A" CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="54"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#FF252525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="重命名" Foreground="#CCCCCC" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Border>

            <!-- 内容 -->
            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock Text="新文件名（不含扩展名）：" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtName" Height="32" FontSize="13"
                         Background="#FF1A1A1A" Foreground="#EEEEEE"
                         BorderBrush="#FF404040" BorderThickness="1"
                         Padding="8,6" VerticalContentAlignment="Center"
                         TextChanged="TxtName_TextChanged"/>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,16,0">
                <Button Content="取消" Width="70" Height="32" Margin="0,0,10,0"
                        Style="{StaticResource DialogBtnSecondary}" Click="BtnCancel_Click"/>
                <Button x:Name="BtnOK" Content="确定" Width="70" Height="32"
                        Style="{StaticResource DialogBtnPrimary}" Click="BtnOK_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
